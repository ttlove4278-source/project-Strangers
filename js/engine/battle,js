const BattleEngine = {
    gameState: null, enemy: null, turn: 0,
    playerLogos: 0, enemyLogos: 0, playerMaxLogos: 0, enemyMaxLogos: 0,
    isPlayerTurn: true, onComplete: null, battleActive: false,
    init(gs) { this.gameState = gs; },
    async startBattle(enemyData, onComplete) {
        this.enemy = { ...enemyData }; this.onComplete = onComplete; this.turn = 1;
        this.playerLogos = this.gameState.player.logos; this.playerMaxLogos = this.gameState.player.maxLogos;
        this.enemyLogos = this.enemy.logos; this.enemyMaxLogos = this.enemy.maxLogos;
        this.isPlayerTurn = true; this.battleActive = true;
        AudioManager.playTenseBGM();
        await SceneManager.switchTo('battle-screen', 'crt');
        await Effects.wait(300); this.updateUI();
        await this.showDeclaration(this.enemy.declaration);
        await this.narrate(this.enemy.openingText);
        await Effects.wait(500); this.showActions();
    },
    updateUI() {
        document.getElementById('battle-player-name').textContent = '夏目珀';
        document.getElementById('battle-player-source').textContent = 'CAMUS';
        document.getElementById('battle-player-logos').style.width = `${(this.playerLogos/this.playerMaxLogos)*100}%`;
        document.getElementById('battle-player-logos-text').textContent = `${this.playerLogos.toFixed(1)} / ${this.playerMaxLogos} 赫`;
        document.getElementById('battle-enemy-name').textContent = this.enemy.name;
        document.getElementById('battle-enemy-source').textContent = this.enemy.source;
        document.getElementById('battle-enemy-logos').style.width = `${(this.enemyLogos/this.enemyMaxLogos)*100}%`;
        document.getElementById('battle-enemy-logos-text').textContent = `${this.enemyLogos.toFixed(1)} / ${this.enemyMaxLogos} 赫`;
        document.getElementById('battle-turn').textContent = `TURN ${this.turn}`;
    },
    async showDeclaration(text) {
        const el = document.getElementById('battle-declaration');
        el.textContent = text; el.classList.remove('active'); void el.offsetWidth;
        el.classList.add('active'); AudioManager.playImpact();
        await Effects.wait(2000); el.classList.remove('active');
    },
    async narrate(text) {
        const el = document.getElementById('battle-narration');
        await Effects.typeText(el, text, 'normal'); await Effects.wait(800);
    },
    _setActionsEnabled(enabled) {
        const p = document.getElementById('battle-actions-panel');
        p.style.opacity = enabled ? '1' : '0.3';
        p.style.pointerEvents = enabled ? 'auto' : 'none';
    },
    showActions() {
        if (!this.battleActive) return;
        const grid = document.getElementById('battle-actions-grid'); grid.innerHTML = '';
        const acts = [
            { id:'quote', label:'引用', cost:0.8, desc:'+攻击' },
            { id:'proposition', label:'命题展开', cost:3.0, desc:'强攻击' },
            { id:'listen', label:'倾听', cost:0, desc:'解析弱点' },
            { id:'silence', label:'沉默', cost:-1.5, desc:'回复' },
        ];
        acts.forEach(a => {
            const btn = document.createElement('button'); btn.className = 'battle-action-btn';
            if (a.cost > 0 && this.playerLogos < a.cost) btn.classList.add('disabled');
            btn.innerHTML = `<span>${a.label}</span><span class="battle-action-cost">${a.cost > 0 ? a.cost+'赫' : a.cost < 0 ? '+'+Math.abs(a.cost)+'赫' : '0赫'}</span>`;
            btn.addEventListener('click', () => this.playerAction(a.id, a.cost));
            grid.appendChild(btn);
        });
        this.showHand();
    },
    showHand() {
        const hand = document.getElementById('battle-hand'); hand.innerHTML = '';
        const quotes = this.gameState.player.quotes.length > 0 ? this.gameState.player.quotes :
            [{ source:'CAMUS', name:'荒谬', effect:'造成1.5赫伤害', cost:0.8 },
             { source:'CAMUS', name:'反抗', effect:'造成2赫伤害', cost:1.2 }];
        quotes.forEach(q => {
            const c = document.createElement('div'); c.className = 'quote-card';
            c.innerHTML = `<div class="quote-card-source">${q.source}</div><div class="quote-card-name">${q.name}</div><div class="quote-card-effect">${q.effect}</div><div class="quote-card-cost">${q.cost}赫</div>`;
            if (this.playerLogos >= q.cost) c.addEventListener('click', () => this.useQuote(q));
            else c.style.opacity = '0.3';
            hand.appendChild(c);
        });
    },
    async playerAction(id, cost) {
        if (!this.isPlayerTurn || !this.battleActive) return;
        this.isPlayerTurn = false; this._setActionsEnabled(false);
        if (id === 'quote') await this.doQuote();
        else if (id === 'proposition') { if (this.playerLogos < 3) { await this.narrate('逻各斯不足。'); this.isPlayerTurn = true; this._setActionsEnabled(true); return; } await this.doProposition(); }
        else if (id === 'listen') await this.doListen();
        else if (id === 'silence') await this.doSilence();
        if (!this.battleActive) return;
        if (this.enemyLogos <= 0) { await this.victory(); return; }
        await this.enemyTurn();
        if (this.playerLogos <= 0) { await this.defeat(); return; }
        this.turn++; this.isPlayerTurn = true; this.updateUI(); this._setActionsEnabled(true); this.showActions();
    },
    async doQuote() {
        const dmg = 1.2 + Math.random() * 0.8;
        this.playerLogos = Math.max(0, this.playerLogos - 0.8);
        this.enemyLogos = Math.max(0, this.enemyLogos - dmg); this.updateUI();
        Effects.spawnLogosParticles(window.innerWidth/2, window.innerHeight/2, 6);
        await this.narrate(`引用·加缪——\n「荒谬不在人，也不在世界，而在两者的共存。」\n\n造成 ${dmg.toFixed(1)} 赫伤害。`);
    },
    async doProposition() {
        await this.showDeclaration('「我们必须想象西西弗是幸福的。」');
        const multi = this.enemy._weaknessRevealed ? 1.5 : 1;
        const dmg = (3.5 + Math.random() * 1.5) * multi;
        this.playerLogos = Math.max(0, this.playerLogos - 3);
        this.enemyLogos = Math.max(0, this.enemyLogos - dmg); this.updateUI();
        Effects.flash(); Effects.shake(); await Effects.wait(300);
        Effects.spawnLogosParticles(window.innerWidth/2, window.innerHeight/2, 15);
        await this.narrate(`命题展开——「西西弗的愉悦」\n\n造成 ${dmg.toFixed(1)} 赫伤害。${multi > 1 ? '\n（弱点暴露 — 增幅）' : ''}`);
    },
    async doListen() {
        this.enemy._weaknessRevealed = true;
        await this.narrate(`你停下来。闭上嘴。打开耳朵。\n\n——${this.enemy.name}的命题：\n「${this.enemy.declaration}」\n\n核心矛盾：${this.enemy.weakness}\n\n下次攻击伤害 +50%。`);
    },
    async doSilence() {
        this.playerLogos = Math.min(this.playerMaxLogos, this.playerLogos + 1.5); this.updateUI();
        await this.narrate('你沉默了。\n蝉在叫。世界暂时接受了你的不发声。\n逻各斯回复 1.5 赫。');
    },
    async useQuote(q) {
        if (this.playerLogos < q.cost || !this.isPlayerTurn) return;
        this.isPlayerTurn = false; this._setActionsEnabled(false);
        const multi = this.enemy._weaknessRevealed ? 1.5 : 1;
        const baseDmg = parseFloat(q.effect.match(/[\d.]+/)?.[0] || 1.5);
        const dmg = baseDmg * multi;
        this.playerLogos = Math.max(0, this.playerLogos - q.cost);
        this.enemyLogos = Math.max(0, this.enemyLogos - dmg); this.updateUI();
        Effects.spawnLogosParticles(window.innerWidth/2, window.innerHeight/2, 4);
        await this.narrate(`引用 ${q.source}·${q.name}\n\n造成 ${dmg.toFixed(1)} 赫伤害。${multi > 1 ? '\n（弱点暴露 — 增幅）' : ''}`);
        if (this.enemyLogos <= 0) { await this.victory(); return; }
        await this.enemyTurn();
        if (this.playerLogos <= 0) { await this.defeat(); return; }
        this.turn++; this.isPlayerTurn = true; this.updateUI(); this._setActionsEnabled(true); this.showActions();
    },
    async enemyTurn() {
        const acts = this.enemy.actions;
        const act = acts[Math.floor(Math.random() * acts.length)];
        await Effects.wait(500);
        if (act.type === 'attack') {
            const dmg = act.damage + Math.random() * act.variance;
            this.playerLogos = Math.max(0, this.playerLogos - dmg);
            Effects.shake(); this.updateUI();
            await this.narrate(`${this.enemy.name}：\n「${act.dialogue}」\n\n${act.description}\n受到 ${dmg.toFixed(1)} 赫伤害。`);
        } else if (act.type === 'heal') {
            this.enemyLogos = Math.min(this.enemyMaxLogos, this.enemyLogos + act.amount); this.updateUI();
            await this.narrate(`${this.enemy.name}：\n「${act.dialogue}」\n\n${act.description}\n回复 ${act.amount} 赫。`);
        } else if (act.type === 'monologue') {
            await this.narrate(`${this.enemy.name}：\n「${act.dialogue}」\n\n${act.description}`);
        }
    },
    async victory() {
        this.battleActive = false; AudioManager.stopBGM(); AudioManager.playClick();
        await Effects.wait(500);
        const r = document.getElementById('battle-result');
        document.getElementById('battle-result-title').textContent = '命题証明';
        document.getElementById('battle-result-title').className = 'battle-result-title win';
        document.getElementById('battle-result-text').textContent = this.enemy.defeatText || '对方的命题崩溃了。';
        document.getElementById('battle-result-btn').textContent = '继续';
        r.classList.add('visible');
        this.gameState.player.logos = Math.min(this.playerMaxLogos, this.playerLogos + 0.3 * this.enemyMaxLogos);
        document.getElementById('battle-result-btn').onclick = () => { r.classList.remove('visible'); if (this.onComplete) this.onComplete('win'); };
    },
    async defeat() {
        this.battleActive = false; await Effects.wait(300);
        const r = document.getElementById('battle-result');
        document.getElementById('battle-result-title').textContent = '命题崩壊';
        document.getElementById('battle-result-title').className = 'battle-result-title lose';
        document.getElementById('battle-result-text').textContent = this.enemy.playerDefeatText || '你的逻各斯归零。\n意识沉入黑暗。';
        document.getElementById('battle-result-btn').textContent = '石头在山脚。';
        r.classList.add('visible');
        document.getElementById('battle-result-btn').onclick = () => { r.classList.remove('visible'); if (this.onComplete) this.onComplete('lose'); };
    }
};
