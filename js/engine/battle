/**
 * 世纪末异邦人 — 战斗系统「命题展开」
 */

const BattleEngine = {
    gameState: null,
    enemy: null,
    turn: 0,
    playerLogos: 0,
    enemyLogos: 0,
    playerMaxLogos: 0,
    enemyMaxLogos: 0,
    battleLog: [],
    isPlayerTurn: true,
    onComplete: null,
    battleActive: false,

    init(gs) { this.gameState = gs; },

    async startBattle(enemyData, onComplete) {
        this.enemy = { ...enemyData };
        this.onComplete = onComplete;
        this.turn = 1;
        this.playerLogos = this.gameState.player.logos;
        this.playerMaxLogos = this.gameState.player.maxLogos;
        this.enemyLogos = this.enemy.logos;
        this.enemyMaxLogos = this.enemy.maxLogos;
        this.isPlayerTurn = true;
        this.battleActive = true;
        this.battleLog = [];

        AudioManager.playTenseBGM();

        await SceneManager.switchTo('battle-screen', 'crt');
        await Effects.wait(300);

        this.updateUI();

        // 开场演出
        await this.showDeclaration(this.enemy.declaration);
        await this.narrate(this.enemy.openingText);
        await Effects.wait(500);

        this.showActions();
    },

    updateUI() {
        document.getElementById('battle-player-name').textContent = '夏目珀';
        document.getElementById('battle-player-source').textContent = 'CAMUS';
        document.getElementById('battle-player-logos').style.width = `${(this.playerLogos / this.playerMaxLogos) * 100}%`;
        document.getElementById('battle-player-logos-text').textContent = `${this.playerLogos.toFixed(1)} / ${this.playerMaxLogos} 赫`;

        document.getElementById('battle-enemy-name').textContent = this.enemy.name;
        document.getElementById('battle-enemy-source').textContent = this.enemy.source;
        document.getElementById('battle-enemy-logos').style.width = `${(this.enemyLogos / this.enemyMaxLogos) * 100}%`;
        document.getElementById('battle-enemy-logos-text').textContent = `${this.enemyLogos.toFixed(1)} / ${this.enemyMaxLogos} 赫`;

        document.getElementById('battle-turn').textContent = `TURN ${this.turn}`;
    },

    async showDeclaration(text) {
        const el = document.getElementById('battle-declaration');
        el.textContent = text;
        el.classList.remove('active');
        void el.offsetWidth;
        el.classList.add('active');
        AudioManager.playImpact();
        await Effects.wait(2000);
        el.classList.remove('active');
    },

    async narrate(text) {
        const el = document.getElementById('battle-narration');
        await Effects.typeText(el, text, 'normal');
        await Effects.wait(800);
    },

    showActions() {
        if (!this.battleActive) return;
        const grid = document.getElementById('battle-actions-grid');
        grid.innerHTML = '';

        const actions = [
            { id: 'quote', label: '引用', cost: 0.8, desc: '哲学碎片攻击' },
            { id: 'proposition', label: '命题展开', cost: 3.0, desc: '宣言你的命题' },
            { id: 'listen', label: '倾听', cost: 0, desc: '解析敌方弱点' },
            { id: 'silence', label: '沉默', cost: -1.5, desc: '回复逻各斯' },
        ];

        actions.forEach(a => {
            const btn = document.createElement('button');
            btn.className = 'battle-action-btn';
            if (a.cost > 0 && this.playerLogos < a.cost) btn.classList.add('disabled');
            btn.innerHTML = `
                <span>${a.label}</span>
                <span class="battle-action-cost">${a.cost > 0 ? a.cost + '赫' : a.cost < 0 ? '+' + Math.abs(a.cost) + '赫' : '0赫'}</span>
            `;
            btn.addEventListener('click', () => this.playerAction(a.id, a.cost));
            grid.appendChild(btn);
        });

        // 引用手牌
        this.showHand();
    },

    showHand() {
        const hand = document.getElementById('battle-hand');
        hand.innerHTML = '';

        const quotes = this.gameState.player.quotes.length > 0
            ? this.gameState.player.quotes
            : [
                { source: 'CAMUS', name: '荒谬', effect: '造成1.5赫伤害', cost: 0.8 },
                { source: 'CAMUS', name: '反抗', effect: '造成2赫伤害，自损0.5赫', cost: 1.2 },
                { source: 'PLATO', name: '洞穴', effect: '揭示敌方下一行动', cost: 0.5 },
            ];

        quotes.forEach((q, i) => {
            const card = document.createElement('div');
            card.className = 'quote-card';
            card.innerHTML = `
                <div class="quote-card-source">${q.source}</div>
                <div class="quote-card-name">${q.name}</div>
                <div class="quote-card-effect">${q.effect}</div>
                <div class="quote-card-cost">${q.cost}赫</div>
            `;
            card.addEventListener('click', () => this.useQuote(q));
            hand.appendChild(card);
        });
    },

    async playerAction(id, cost) {
        if (!this.isPlayerTurn || !this.battleActive) return;
        this.isPlayerTurn = false;
        document.getElementById('battle-actions-panel').style.opacity = '0.3';
        document.getElementById('battle-actions-panel').style.pointerEvents = 'none';

        switch (id) {
            case 'quote':
                await this.doQuote();
                break;
            case 'proposition':
                await this.doProposition();
                break;
            case 'listen':
                await this.doListen();
                break;
            case 'silence':
                await this.doSilence();
                break;
        }

        if (!this.battleActive) return;

        // 检查胜利
        if (this.enemyLogos <= 0) { await this.victory(); return; }

        // 敌方回合
        await this.enemyTurn();

        // 检查败北
        if (this.playerLogos <= 0) { await this.defeat(); return; }

        // 下一回合
        this.turn++;
        this.isPlayerTurn = true;
        this.updateUI();
        document.getElementById('battle-actions-panel').style.opacity = '1';
        document.getElementById('battle-actions-panel').style.pointerEvents = 'auto';
        this.showActions();
    },

    async doQuote() {
        const dmg = 1.2 + Math.random() * 0.8;
        this.playerLogos = Math.max(0, this.playerLogos - 0.8);
        this.enemyLogos = Math.max(0, this.enemyLogos - dmg);
        this.updateUI();

        Effects.spawnLogosParticles(window.innerWidth / 2, window.innerHeight / 2, 6);
        await this.narrate(`你引用了加缪——\n「荒谬不在人，也不在世界，而在两者的共存。」\n\n造成 ${dmg.toFixed(1)} 赫伤害。`);
    },

    async doProposition() {
        if (this.playerLogos < 3) {
            await this.narrate('逻各斯不足。无法展开命题。');
            this.isPlayerTurn = true;
            document.getElementById('battle-actions-panel').style.opacity = '1';
            document.getElementById('battle-actions-panel').style.pointerEvents = 'auto';
            return;
        }

        await this.showDeclaration('「我们必须想象西西弗是幸福的。」');

        const dmg = 3.5 + Math.random() * 1.5;
        this.playerLogos = Math.max(0, this.playerLogos - 3);
        this.enemyLogos = Math.max(0, this.enemyLogos - dmg);
        this.updateUI();

        Effects.flash();
        Effects.shake();
        await Effects.wait(300);
        Effects.spawnLogosParticles(window.innerWidth / 2, window.innerHeight / 2, 15);

        await this.narrate(`命题展开——「西西弗的愉悦」\n\n瞳孔溢出琥珀色的逻各斯。\n加缪的签名在视野中燃烧。\n\n造成 ${dmg.toFixed(1)} 赫伤害。`);
    },

    async doListen() {
        this.enemy._weaknessRevealed = true;
        await this.narrate(`你停下来。闭上嘴。打开耳朵。\n\n——${this.enemy.name}的命题是：\n「${this.enemy.declaration}」\n\n核心矛盾：${this.enemy.weakness}\n\n下次攻击伤害 +50%。`);
    },

    async doSilence() {
        this.playerLogos = Math.min(this.playerMaxLogos, this.playerLogos + 1.5);
        this.updateUI();
        await this.narrate('你沉默了。\n\n蝉在叫。世界暂时接受了你的不发声。\n逻各斯回复 1.5 赫。');
    },

    async useQuote(quote) {
        if (this.playerLogos < quote.cost || !this.isPlayerTurn) return;
        this.isPlayerTurn = false;
        document.getElementById('battle-actions-panel').style.opacity = '0.3';
        document.getElementById('battle-actions-panel').style.pointerEvents = 'none';

        const multi = this.enemy._weaknessRevealed ? 1.5 : 1;
        const dmg = parseFloat(quote.effect.match(/[\d.]+/)?.[0] || 1.5) * multi;
        this.playerLogos = Math.max(0, this.playerLogos - quote.cost);
        this.enemyLogos = Math.max(0, this.enemyLogos - dmg);
        this.updateUI();

        Effects.spawnLogosParticles(window.innerWidth / 2, window.innerHeight / 2, 4);
        await this.narrate(`引用 ${quote.source}·${quote.name}\n\n造成 ${dmg.toFixed(1)} 赫伤害。${multi > 1 ? '\n（弱点暴露 — 伤害增幅）' : ''}`);

        if (this.enemyLogos <= 0) { await this.victory(); return; }
        await this.enemyTurn();
        if (this.playerLogos <= 0) { await this.defeat(); return; }

        this.turn++;
        this.isPlayerTurn = true;
        this.updateUI();
        document.getElementById('battle-actions-panel').style.opacity = '1';
        document.getElementById('battle-actions-panel').style.pointerEvents = 'auto';
        this.showActions();
    },

    async enemyTurn() {
        const actions = this.enemy.actions;
        const action = actions[Math.floor(Math.random() * actions.length)];

        await Effects.wait(500);

        if (action.type === 'attack') {
            const dmg = action.damage + Math.random() * action.variance;
            this.playerLogos = Math.max(0, this.playerLogos - dmg);
            Effects.shake();
            this.updateUI();
            await this.narrate(`${this.enemy.name}：\n「${action.dialogue}」\n\n${action.description}\n你受到 ${dmg.toFixed(1)} 赫伤害。`);
        } else if (action.type === 'heal') {
            this.enemyLogos = Math.min(this.enemyMaxLogos, this.enemyLogos + action.amount);
            this.updateUI();
            await this.narrate(`${this.enemy.name}：\n「${action.dialogue}」\n\n${action.description}\n回复 ${action.amount} 赫。`);
        } else if (action.type === 'monologue') {
            await this.narrate(`${this.enemy.name}：\n「${action.dialogue}」\n\n${action.description}`);
        }
    },

    async victory() {
        this.battleActive = false;
        AudioManager.stopBGM();
        AudioManager.playClick();

        await Effects.wait(500);

        const result = document.getElementById('battle-result');
        const title = document.getElementById('battle-result-title');
        const text = document.getElementById('battle-result-text');

        title.textContent = '命题証明';
        title.className = 'battle-result-title win';
        text.textContent = this.enemy.defeatText || '对方的命题崩溃了。';
        result.classList.add('visible');

        const logosReturn = 0.3 * (this.enemyMaxLogos);
        this.gameState.player.logos = Math.min(this.playerMaxLogos, this.playerLogos + logosReturn);

        document.getElementById('battle-result-btn').onclick = () => {
            result.classList.remove('visible');
            if (this.onComplete) this.onComplete('win');
        };
    },

    async defeat() {
        this.battleActive = false;

        await Effects.wait(300);

        const result = document.getElementById('battle-result');
        const title = document.getElementById('battle-result-title');
        const text = document.getElementById('battle-result-text');

        title.textContent = '命题崩壊';
        title.className = 'battle-result-title lose';
        text.innerHTML = this.enemy.playerDefeatText || '你的逻各斯归零。<br>意识沉入黑暗。';
        result.classList.add('visible');

        document.getElementById('battle-result-btn').textContent = '石头在山脚。';
        document.getElementById('battle-result-btn').onclick = () => {
            result.classList.remove('visible');
            if (this.onComplete) this.onComplete('lose');
        };
    }
};
